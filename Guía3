    private void jMenuItem19ActionPerformed(java.awt.event.ActionEvent evt) {                                            
        // TODO add your handling code here:
        JOptionPane.showMessageDialog(null,
            "Este programa fue desarrollado para mostrar información sobre los principales "
            + "componentes internos de una computadora. Su funcionamiento consiste en presentar "
            + "el concepto y la función principal de cada componente, permitiendo al usuario "
            + "conocer la importancia de la motherboard, el procesador, la memoria RAM, el disco "
            + "duro, la unidad SSD, la fuente de poder, la tarjeta de video, la tarjeta de red, "
            + "el sistema de enfriamiento, la tarjeta de sonido, la batería CMOS, los cables "
            + "SATA y de alimentación, así como el BIOS/UEFI. De esta manera, el programa sirve "
            + "como una herramienta educativa para comprender cómo trabajan en conjunto los "
            + "componentes de una computadora.",
            "Acerca del Programa",
            JOptionPane.INFORMATION_MESSAGE);
    }                                           

